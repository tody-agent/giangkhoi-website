---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n';

const t = useTranslations('vi');

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Liên hệ Xe Cẩu Giang Khôi",
  "url": "https://xecaugiangkhoi.com/vi/lien-he"
};
---

<BaseLayout 
  title="Liên Hệ Xe Cẩu Giang Khôi — Gọi Ngay 0971 491 174"
  description="Liên hệ dịch vụ xe cẩu Giang Khôi Hưng Yên. Gọi 0971 491 174 hoặc chat Zalo để nhận báo giá trong 5 phút. Phục vụ 24/7."
  jsonLd={jsonLd}
>
  <section class="section" style="padding-top: var(--space-12);">
    <div class="container">
      <div class="section-header">
        <h1>Liên Hệ Giang Khôi</h1>
        <p>{t('contact.subtitle')}</p>
      </div>

      <div class="contact-grid">
        <!-- Contact Cards -->
        <div class="contact-methods">
          <a href="tel:0971491174" class="contact-card contact-phone" id="contact-phone">
            <span class="contact-icon">📞</span>
            <h3>Gọi ngay</h3>
            <p class="contact-value">0971 491 174</p>
            <p class="contact-note">Phục vụ 24/7 — Có mặt trong 30 phút</p>
          </a>

          <a href="https://zalo.me/0971491174" target="_blank" rel="noopener" class="contact-card contact-zalo" id="contact-zalo">
            <span class="contact-icon">💬</span>
            <h3>Chat Zalo</h3>
            <p class="contact-value">Zalo: 0971 491 174</p>
            <p class="contact-note">Gửi ảnh công việc để nhận báo giá nhanh</p>
          </a>

          <div class="contact-card contact-address">
            <span class="contact-icon">📍</span>
            <h3>Địa chỉ</h3>
            <p class="contact-value">{t('site.address')}</p>
            <p class="contact-note">{t('site.company')}</p>
            <p class="contact-note">MST: 0901150346</p>
          </div>

          <div class="contact-card">
            <span class="contact-icon">🕐</span>
            <h3>Giờ phục vụ</h3>
            <p class="contact-value">24/7</p>
            <p class="contact-note">Kể cả ngày lễ, Tết — Cứu hộ khẩn cấp mọi lúc</p>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="contact-form-wrapper">
          <h3>Gửi yêu cầu báo giá</h3>
          <p>Để lại thông tin, chúng tôi sẽ gọi lại trong 5 phút.</p>
          <form class="contact-form" id="contact-form" action="https://api.web3forms.com/submit" method="POST">
            <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
            <input type="hidden" name="subject" value="Yêu cầu báo giá xe cẩu — xecaugiangkhoi.com" />
            <input type="hidden" name="redirect" value="https://xecaugiangkhoi.com/vi/lien-he?success=true" />
            
            <!-- Honeypot anti-spam -->
            <div style="position: absolute; left: -9999px;">
              <input type="text" name="botcheck" tabindex="-1" autocomplete="off" />
            </div>

            <div class="form-group">
              <label for="name">{t('contact.name')} *</label>
              <input type="text" id="name" name="name" required placeholder="Nguyễn Văn A" />
            </div>

            <div class="form-group">
              <label for="phone">{t('contact.phone')} *</label>
              <input type="tel" id="phone" name="phone" required placeholder="0971 xxx xxx" />
            </div>

            <div class="form-group">
              <label for="message">{t('contact.message')}</label>
              <textarea id="message" name="message" rows="4" placeholder="VD: Cần cẩu bồn nước 1000L lên tầng 3, địa chỉ tại Mỹ Hào..."></textarea>
            </div>

            <button type="submit" class="btn btn-primary btn-lg" style="width: 100%;" id="form-submit">
              {t('contact.submit')}
            </button>
          </form>
        </div>
      </div>

      <!-- Map embed -->
      <div class="map-section">
        <h3>Vị trí trụ sở</h3>
        <div class="map-embed">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3723.5!2d106.068!3d20.9397!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sBach+Sam+My+Hao+Hung+Yen!5e0!3m2!1svi!2svn!4v1680000000000!5m2!1svi!2svn" 
            width="100%" 
            height="400" 
            style="border:0; border-radius: var(--radius-xl);" 
            allowfullscreen 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            title="Bản đồ Giang Khôi - Mỹ Hào, Hưng Yên"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-methods {
    display: grid;
    gap: var(--space-4);
  }

  .contact-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    text-decoration: none;
    color: inherit;
    transition: all var(--transition-base);
    display: block;
  }

  .contact-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
  }

  .contact-phone:hover {
    border-color: var(--color-success);
  }

  .contact-zalo:hover {
    border-color: #0068FF;
  }

  .contact-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: var(--space-2);
  }

  .contact-card h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }

  .contact-value {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .contact-note {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* Form */
  .contact-form-wrapper {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
  }

  .contact-form-wrapper h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }

  .contact-form-wrapper > p {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    margin-bottom: var(--space-6);
  }

  .form-group {
    margin-bottom: var(--space-4);
  }

  .form-group label {
    display: block;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    margin-bottom: var(--space-2);
    color: var(--color-text-secondary);
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: var(--text-base);
    transition: border-color var(--transition-fast);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-glow);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--color-text-muted);
  }

  /* Map */
  .map-section h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-4);
  }
</style>
