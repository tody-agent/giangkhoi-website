---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n';

const t = useTranslations('vi');

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "CÔNG TY TNHH THƯƠNG MẠI DỊCH VỤ VẬN TẢI GIANG KHÔI HƯNG YÊN",
  "url": "https://xecaugiangkhoi.com",
  "telephone": "+84971491174",
  "foundingDate": "2016",
  "founder": {
    "@type": "Person",
    "name": "Vũ Văn Hùng"
  },
  "numberOfEmployees": { "@type": "QuantitativeValue", "value": 12 },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Số 2013 Nguyễn Văn Linh, Phường Bạch Sam",
    "addressLocality": "Mỹ Hào",
    "addressRegion": "Hưng Yên",
    "addressCountry": "VN"
  },
  "taxID": "0901150346",
  "description": "Dịch vụ cho thuê xe cẩu uy tín tại Hưng Yên. 10 năm kinh nghiệm, đội 6 xe cẩu từ 3.5T đến 100T."
};
---

<BaseLayout 
  title="Về Giang Khôi — 10 Năm Xe Cẩu Uy Tín Hưng Yên"
  description="Tìm hiểu về Vận Tải Giang Khôi — 10 năm kinh nghiệm cho thuê xe cẩu tại Hưng Yên. Đội 6 xe, phục vụ 24/7, uy tín hàng đầu khu vực."
  jsonLd={jsonLd}
>
  <section class="section" style="padding-top: var(--space-12);">
    <div class="container">
      <div class="section-header">
        <span class="badge badge-primary">Từ 2016</span>
        <h1>Về Vận Tải Giang Khôi</h1>
        <p>10 năm gắn bó — Hàng trăm công trình tin tưởng</p>
      </div>

      <article class="about-content">
        <div class="about-intro">
          <h2>Câu chuyện của chúng tôi</h2>
          <p><strong>Vận Tải Giang Khôi</strong> được thành lập năm 2016 tại Mỹ Hào, Hưng Yên — trung tâm các khu công nghiệp lớn nhất miền Bắc. Xuất phát từ 1 chiếc xe cẩu duy nhất, qua 10 năm phát triển, Giang Khôi đã xây dựng đội <strong>6 xe cẩu đa dạng tải trọng từ 3.5 tấn đến 100 tấn</strong>.</p>
          <p>Chúng tôi hiểu rằng khi anh/chị cần xe cẩu, đó thường là lúc <strong>GẤP</strong>. Xe tải lật giữa đường, container cần rút gấp, hay máy mới về xưởng phải hạ ngay — đó là lý do cam kết <strong>"Có mặt trong 30 phút"</strong> luôn là ưu tiên số 1 của Giang Khôi.</p>
        </div>

        <div class="stats-grid">
          <div class="stat-card">
            <span class="stat-value">10+</span>
            <span class="stat-label">Năm kinh nghiệm</span>
          </div>
          <div class="stat-card">
            <span class="stat-value">6</span>
            <span class="stat-label">Xe cẩu sẵn sàng</span>
          </div>
          <div class="stat-card">
            <span class="stat-value">500+</span>
            <span class="stat-label">Công trình phục vụ</span>
          </div>
          <div class="stat-card">
            <span class="stat-value">30'</span>
            <span class="stat-label">Phút có mặt</span>
          </div>
        </div>

        <div class="about-section">
          <h2>Cam kết dịch vụ uy tín</h2>
          <div class="grid grid-3">
            <div class="commitment-card">
              <h3>⚡ KHÔNG chờ lâu</h3>
              <p>Đội xe đóng tại Mỹ Hào — trung tâm Hưng Yên. Bất kể ngày hay đêm, xe cẩu có mặt trong 30 phút cho bán kính 30km.</p>
            </div>
            <div class="commitment-card">
              <h3>💎 KHÔNG phí ẩn</h3>
              <p>Báo giá rõ ràng qua điện thoại trước khi làm. Giá cố định theo tải trọng. Không phát sinh — không bất ngờ.</p>
            </div>
            <div class="commitment-card">
              <h3>🤝 ĐẦY ĐỦ hóa đơn</h3>
              <p>Cung cấp đầy đủ hóa đơn VAT, hợp đồng và chứng từ giao nhận rõ ràng, minh bạch cho doanh nghiệp.</p>
            </div>
          </div>
        </div>

        <div class="about-section">
          <h2>Giấy tờ pháp lý & Mã số thuế</h2>
          <dl class="legal-info">
            <dt>Tên công ty</dt>
            <dd>CÔNG TY TNHH THƯƠNG MẠI DỊCH VỤ VẬN TẢI GIANG KHÔI HƯNG YÊN</dd>
            <dt>Mã số thuế</dt>
            <dd>0901150346</dd>
            <dt>Người đại diện pháp luật</dt>
            <dd>VŨ VĂN HÙNG</dd>
            <dt>Tình trạng hoạt động</dt>
            <dd>Đang hoạt động (Đầy đủ năng lực pháp lý ký hợp đồng & xuất hóa đơn VAT B2B)</dd>
            <dt>Địa chỉ đăng ký thuế</dt>
            <dd>Số 2013 Nguyễn Văn Linh, Phường Thượng Hồng, Tỉnh Hưng Yên, Việt Nam</dd>
            <dt>Địa chỉ văn phòng & bãi xe</dt>
            <dd>Số 2013 Nguyễn Văn Linh, Phường Bạch Sam, Thị xã Mỹ Hào, Tỉnh Hưng Yên, Việt Nam</dd>
            <dt>Ngành nghề chính</dt>
            <dd>Cho thuê xe cẩu, Vận tải hàng hóa bằng đường bộ, Lắp đặt máy móc thiết bị công nghiệp</dd>
            <dt>Kiểm định an toàn</dt>
            <dd>Toàn bộ 6 xe đều có giấy kiểm định còn hạn, tài xế có chứng chỉ vận hành, đủ điều kiện vào tất cả KCN tại Hưng Yên, Bắc Ninh, Hải Dương</dd>
          </dl>
        </div>

        <div class="about-section">
          <h2>Danh mục ngành nghề kinh doanh (Hỗ trợ xuất hóa đơn VAT B2B)</h2>
          <p class="text-secondary" style="font-size: var(--text-sm); margin-bottom: var(--space-4);">Để đáp ứng yêu cầu quyết toán thuế và hồ sơ thầu của các doanh nghiệp trong KCN, Giang Khôi đăng ký đầy đủ các mã ngành công nghiệp phụ trợ dưới đây và hỗ trợ xuất hóa đơn VAT tương ứng:</p>
          
          <div class="price-table-wrapper">
            <table class="sectors-table">
              <thead>
                <tr>
                  <th>Mã ngành</th>
                  <th>Tên ngành nghề kinh doanh</th>
                  <th>Hỗ trợ dịch vụ thực tế tại Giang Khôi</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td><strong>7730</strong> (Chính)</td>
                  <td>Cho thuê máy móc, thiết bị và đồ dùng hữu hình khác</td>
                  <td><a href="/vi/bang-gia">Cho thuê xe cẩu tự hành, xe cẩu Kato 3.5T - 100T</a></td>
                </tr>
                <tr>
                  <td><strong>4933</strong> (Chính)</td>
                  <td>Vận tải hàng hóa bằng đường bộ</td>
                  <td><a href="/vi/dich-vu/cau-container">Vận chuyển container, cẩu chuyển hàng siêu trường siêu trọng</a></td>
                </tr>
                <tr>
                  <td><strong>3320</strong></td>
                  <td>Lắp đặt máy móc và thiết bị công nghiệp</td>
                  <td><a href="/vi/dich-vu/cau-may-mong-xuong">Nâng hạ, định vị và lắp đặt máy móc xưởng, máy CNC</a></td>
                </tr>
                <tr>
                  <td><strong>5224</strong></td>
                  <td>Bốc xếp hàng hóa</td>
                  <td><a href="/vi/dich-vu/cau-container">Rút ruột container, bốc xếp nâng hạ máy móc thiết bị</a></td>
                </tr>
                <tr>
                  <td><strong>8130</strong></td>
                  <td>Dịch vụ chăm sóc và duy trì cảnh quan</td>
                  <td><a href="/vi/dich-vu/cau-cay-canh">Cẩu và di dời cây cảnh lớn, cây công trình đô thị</a></td>
                </tr>
                <tr>
                  <td><strong>4311 & 4312</strong></td>
                  <td>Phá dỡ & Chuẩn bị mặt bằng</td>
                  <td><a href="/vi/dich-vu/cau-vat-lieu-xay-nha">Cẩu phá dỡ, thu dọn xà bần, chuẩn bị mặt bằng thi công</a></td>
                </tr>
                <tr>
                  <td><strong>4322 & 4329</strong></td>
                  <td>Lắp đặt hệ thống xây dựng khác</td>
                  <td><a href="/vi/dich-vu/cau-mai-ton-khung-keo">Cẩu lắp đặt bồn nước, mái tôn, khung thép nhà xưởng</a></td>
                </tr>
              </tbody>
            </table>
          </div>

          <details class="legal-details">
            <summary>Xem thêm các mã ngành đăng ký phụ trợ khác (50+ ngành nghề)</summary>
            <div class="all-codes-grid">
              <div class="code-item"><span class="code-num">2395</span><span>Sản xuất bê tông và các sản phẩm từ xi măng, thạch cao</span></div>
