              <div class="code-item"><span class="code-num">3812</span><span>危险废物收集</span></div>
              <div class="code-item"><span class="code-num">3821</span><span>非危险废物处置</span></div>
              <div class="code-item"><span class="code-num">3822</span><span>危险废物处置</span></div>
              <div class="code-item"><span class="code-num">3830</span><span>废旧金属与塑料回收再利用</span></div>
              <div class="code-item"><span class="code-num">3900</span><span>污染治理及其他废物管理</span></div>
              <div class="code-item"><span class="code-num">4330</span><span>建筑装饰装修与工程收尾</span></div>
              <div class="code-item"><span class="code-num">4511</span><span>汽车及其他机动车批发</span></div>
              <div class="code-item"><span class="code-num">4520</span><span>汽车及机动车维护和修理</span></div>
              <div class="code-item"><span class="code-num">4530</span><span>汽车配件及零配件批发</span></div>
