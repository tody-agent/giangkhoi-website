<style>
  .about-content { max-width: 900px; margin: 0 auto; }
  .about-intro { margin-bottom: var(--space-12); }
  .about-intro h2 { margin-bottom: var(--space-4); }
  .about-intro p { color: var(--color-text-secondary); font-size: var(--text-lg); line-height: 1.9; }
  .stats-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-4); margin-bottom: var(--space-12); }
  @media (min-width: 640px) { .stats-grid { grid-template-columns: repeat(4, 1fr); } }
  .stat-card { background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-6); text-align: center; }
  .stat-value { display: block; font-family: var(--font-heading); font-size: var(--text-4xl); font-weight: var(--weight-extrabold); color: var(--color-primary); line-height: 1; margin-bottom: var(--space-2); }
  .stat-label { font-size: var(--text-sm); color: var(--color-text-muted); font-weight: var(--weight-medium); }
  .about-section { margin-bottom: var(--space-12); }
  .about-section h2 { margin-bottom: var(--space-6); }
  .commitment-card { background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-6); }
  .commitment-card h3 { font-size: var(--text-lg); margin-bottom: var(--space-3); color: var(--color-primary); }
  .commitment-card p { color: var(--color-text-secondary); font-size: var(--text-sm); line-height: 1.8; }
  .legal-info { background: var(--color-bg-card); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: var(--space-6); }
  .legal-info dt { font-weight: var(--weight-semibold); color: var(--color-text); font-size: var(--text-sm); margin-top: var(--space-4); }
  .legal-info dt:first-child { margin-top: 0; }
  .legal-info dd { color: var(--color-text-secondary); font-size: var(--text-sm); margin-left: 0; padding-bottom: var(--space-3); border-bottom: 1px solid var(--color-border); }
  .legal-info dd:last-child { border-bottom: none; padding-bottom: 0; }

  .sectors-table {
    width: 100%;
    margin-top: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-card);
  }

  .sectors-table th, .sectors-table td {
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-sm);
    text-align: left;
    border-bottom: 1px solid var(--color-border);
  }

  .sectors-table th {
    background: var(--color-bg-elevated);
    color: var(--color-primary);
    font-weight: var(--weight-semibold);
  }

  .sectors-table tr:last-child td {
    border-bottom: none;
  }

  .sectors-table td a {
    color: var(--color-primary);
    font-weight: var(--weight-medium);
  }

  .sectors-table td a:hover {
    color: var(--color-primary-hover);
    text-decoration: underline;
  }
  
  .legal-details {
    margin-top: var(--space-6);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-5);
  }

  .legal-details summary {
    cursor: pointer;
    font-weight: var(--weight-semibold);
    color: var(--color-primary);
    outline: none;
    user-select: none;
    font-size: var(--text-base);
  }

  .legal-details summary:hover {
    color: var(--color-primary-hover);
  }

  .all-codes-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    margin-top: var(--space-5);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  @media (min-width: 640px) {
    .all-codes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .code-item {
    display: flex;
    gap: var(--space-3);
    padding: var(--space-2) 0;
    border-bottom: 1px dashed var(--color-border);
    align-items: baseline;
  }

  .code-num {
    font-weight: var(--weight-bold);
    color: var(--color-primary);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    background: var(--color-bg-elevated);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-border);
  }
</style>
